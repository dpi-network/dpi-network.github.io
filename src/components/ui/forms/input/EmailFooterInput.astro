---
const {
  label = "Search",
  title = Astro.currentLocale === "fr" ? "S'abonner" : "Subscribe",
  id = "footer-input",
} = Astro.props;

interface Props {
  label?: string;
  title?: string;
  id?: string;
}

const placeholder = Astro.currentLocale === "fr" ? "Entrez votre email" : "Enter your email";

import { NEWSLETTER } from "../../../../data_files/constants";
---

{NEWSLETTER.embedUid ? (
  <div class="mt-4">
    <p class="sr-only">{label}</p>
    <div id={`convertkit-embed-${NEWSLETTER.embedUid}`} data-kit-embed={NEWSLETTER.embedUid}></div>
    <script async data-uid={NEWSLETTER.embedUid} src={`https://data-for-public-impact-network.kit.com/${NEWSLETTER.embedUid}/index.js`}></script>
    <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>
  </div>
) : (
  <form
    id={id}
    class="flex w-full flex-col items-center justify-center gap-2 sm:flex-row"
    action={import.meta.env.PUBLIC_KIT_FORM_ACTION_URL ?? ""}
    method="post"
    target="_blank"
  >
    <label for={id} class="sr-only">{label}</label>
    <input
      type="email"
      name="email_address"
      placeholder={placeholder}
      required
      class="w-full rounded-lg border border-neutral-300 bg-white px-4 py-2 text-sm text-neutral-900 placeholder:text-neutral-400 focus:border-primary-500 focus:ring-primary-500 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-100 dark:placeholder:text-neutral-500 sm:max-w-xs"
    />
    <button
      type="submit"
      class="w-full rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white transition duration-300 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 dark:focus:ring-offset-black sm:w-auto"
    >
      {title}
    </button>
  </form>
)}
