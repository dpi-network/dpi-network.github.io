---
interface Props {
  name: string
  logoSrc: string
  hasLogo: boolean
}

const { name, logoSrc, hasLogo } = Astro.props as Props
---

{
  hasLogo ? (
    <img
      src={logoSrc}
      alt={`${name} logo`}
      loading="lazy"
      class="max-h-full max-w-full object-contain"
    />
  ) : (
    <span
      class="flex items-center justify-center text-neutral-400 dark:text-neutral-500"
      aria-hidden="true"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 640 512"
        class="h-9 w-9 shrink-0 opacity-60 sm:h-10 sm:w-10"
        fill="currentColor"
      >
        <path d="M579.8 267.7c56.5-56.5 56.5-148 0-204.5C523.3 6.7 431.8 6.7 375.3 62.8L190.8 247.3c-38.5 38.5-45.1 102-17.6 150.3L4.5 486.1c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0l168.6-168.6c48.3 27.5 111.8 20.8 150.3-17.6l184.5-184.5z" />
      </svg>
    </span>
  )
}
