---
import { CONTACT } from "@data/constants"
import Icon from "@components/ui/icons/Icon.astro"

const dpiRed = "#ff0101"
const mailto = `mailto:${CONTACT.email}`

const channels = [
  {
    label: "Email",
    description: "Best for partnerships, press, and general questions.",
    href: mailto,
    display: CONTACT.email,
    external: false,
    icon: "email" as const,
  },
  {
    label: "LinkedIn",
    description: "Updates, events, and community highlights.",
    href: CONTACT.linkedin,
    display: "Company page",
    external: true,
    icon: "linkedin" as const,
  },
  {
    label: "Instagram",
    description: "Behind-the-scenes from hackathons and the network.",
    href: CONTACT.instagram,
    display: "@dpi.network",
    external: true,
    icon: "instagram" as const,
  },
]
---

<section
  class="mx-auto max-w-[85rem] px-4 pb-16 pt-10 sm:px-6 sm:pb-20 lg:px-8 lg:pt-14"
>
  <div class="mx-auto max-w-5xl">
    <header class="text-center">
      <h1
        class="flex flex-wrap items-center justify-center gap-3 text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-100 md:text-4xl md:leading-tight"
      >
        <span
          class="inline-block h-8 w-1.5 shrink-0 rounded-full md:h-10"
          style={`background-color: ${dpiRed}`}
          aria-hidden="true"
        />
        <span>Get in touch</span>
      </h1>
      <p
        class="mx-auto mt-3 max-w-2xl text-pretty text-neutral-600 dark:text-neutral-400 md:text-lg"
      >
        Whether you want to collaborate, host a policy hackathon, or learn more
        about DPIN, we would love to hear from you!
      </p>
    </header>

    <ul
      class="mt-12 grid gap-4 sm:grid-cols-2 sm:gap-5 lg:mt-14 lg:grid-cols-3"
    >
      {
        channels.map((c) => (
          <li class="h-full list-none">
            <a
              href={c.href}
              class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-neutral-200/90 bg-white shadow-sm transition duration-300 hover:-translate-y-0.5 hover:border-red-200/90 hover:shadow-lg hover:shadow-red-950/5 focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500/60 focus-visible:ring-offset-2 dark:border-neutral-700/90 dark:bg-neutral-900/40 dark:hover:border-red-900/40 dark:hover:shadow-red-950/20 dark:focus-visible:ring-offset-neutral-900"
              target={c.external ? "_blank" : undefined}
              rel={c.external ? "noopener noreferrer" : undefined}
            >
              <div
                class="h-1 w-full shrink-0"
                style={`background-color: ${dpiRed}`}
                aria-hidden="true"
              />
              <div class="flex flex-1 flex-col p-5 sm:p-6">
                <div class="mb-4 flex items-start justify-between gap-3">
                  <div
                    class="flex h-12 w-12 items-center justify-center rounded-xl bg-neutral-100 text-[#ff0101] dark:bg-neutral-800 dark:text-[#ff3838] [&_svg]:!mt-0 [&_svg]:!text-[#ff0101] dark:[&_svg]:!text-[#ff3838]"
                    aria-hidden="true"
                  >
                    {c.icon === "email" ? (
                      <Icon name="envelopeOpen" />
                    ) : c.icon === "linkedin" ? (
                      <Icon name="linkedIn" />
                    ) : (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        class="h-7 w-7"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        aria-hidden="true"
                      >
                        <rect x="3" y="3" width="18" height="18" rx="4" />
                        <circle cx="12" cy="12" r="3.25" />
                        <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                      </svg>
                    )}
                  </div>
                  <span class="text-xs font-semibold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">
                    {c.label}
                  </span>
                </div>
                <p class="text-base font-semibold text-neutral-900 dark:text-neutral-100">
                  {c.display}
                </p>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
                  {c.description}
                </p>
                <span
                  class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-[#ff0101] transition group-hover:gap-2 dark:text-[#ff3838]"
                >
                  {c.external ? "Visit" : "Write us"}
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                    />
                  </svg>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>

    <div
      class="mt-12 rounded-2xl border border-dashed border-neutral-300 bg-neutral-100/60 px-5 py-8 text-center dark:border-neutral-600 dark:bg-neutral-900/50 sm:px-8"
    >
      <p class="text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
        Prefer to explore first? Read about
        <a
          href="/about"
          class="font-semibold text-[#ff0101] underline decoration-red-300 underline-offset-2 transition hover:decoration-red-500 dark:text-[#ff3838] dark:decoration-red-800 dark:hover:decoration-red-500"
          >our team</a
        >
        or visit your city&apos;s
        <span class="font-medium text-neutral-800 dark:text-neutral-200"
          >Policy Hackathon</span
        >
        site from the footer.
      </p>
    </div>
  </div>
</section>
