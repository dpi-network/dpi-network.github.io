---
import "leaflet/dist/leaflet.css";
import type { Hackathon } from "@data/hackathons";

interface Props {
  hackathons: Hackathon[];
}

const { hackathons } = Astro.props;
---

<div
  class="hackathon-map-shell relative isolate z-0 overflow-hidden rounded-[36px] border border-red-100/50 bg-neutral-50/50 shadow-sm dark:border-neutral-700/40 dark:bg-neutral-800/80"
>
  <div
    class="relative z-10 flex flex-wrap items-center justify-between gap-3 border-b border-neutral-200/80 bg-neutral-50/95 px-4 py-3 text-xs text-neutral-600 backdrop-blur-sm dark:border-neutral-700/60 dark:bg-neutral-800/95 dark:text-neutral-400 md:px-5"
  >
    <div class="flex items-center gap-2">
      <span
        class="inline-block size-2 rounded-full bg-[#ff0101] shadow-sm dark:bg-[#ff3838]"
        aria-hidden="true"></span>
      <span class="font-medium text-neutral-700 dark:text-neutral-300"
        >Hackathon locations</span
      >
      <span class="text-neutral-400 dark:text-neutral-600">·</span>
      <span
        >{hackathons.length} {hackathons.length === 1 ? "city" : "cities"}</span
      >
    </div>
    <span class="text-neutral-500 dark:text-neutral-500"
      >Ctrl + scroll to zoom · click a pin</span
    >
  </div>
  <div
    id="hackathon-map-root"
    class="relative z-0 h-[min(70vh,520px)] w-full min-h-[320px]"
    role="img"
    aria-label="Interactive map of policy hackathon locations"
    data-hackathons={JSON.stringify(hackathons)}
  >
  </div>
</div>

<script>
  import "@scripts/hackathonMap.ts";
</script>

<style is:global>
  /* Do not override Leaflet pane z-index — popups must stay above markers/tiles (default ~700). */
  .hackathon-map-shell .hm-marker-wrap {
    background: transparent;
    border: none;
  }
  .hackathon-map-shell .hm-pin {
    cursor: pointer;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.45));
  }
  .hackathon-map-shell .hm-pin-svg {
    display: block;
    pointer-events: auto;
  }
  .hackathon-map-shell .hm-popup {
    min-width: 10rem;
    color: #e5e7eb;
  }
  .hackathon-map-shell .hm-popup-title {
    font-weight: 600;
    font-size: 0.9rem;
    color: #f9fafb;
    margin-bottom: 0.25rem;
  }
  .hackathon-map-shell .hm-popup-meta {
    font-size: 0.75rem;
    color: #9ca3af;
    margin-bottom: 0.5rem;
  }
  .hackathon-map-shell .hm-popup-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: #f87171;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .hackathon-map-shell .hm-popup-link:hover {
    color: #fca5a5;
  }
  .hackathon-map-shell .leaflet-popup-content-wrapper {
    background: #262626 !important;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
  }
  .hackathon-map-shell .leaflet-popup-tip {
    background: #262626 !important;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .hackathon-map-shell .leaflet-container .leaflet-control-attribution {
    background: rgba(38, 38, 38, 0.92);
    color: #a3a3a3;
    font-size: 10px;
  }
  .hackathon-map-shell .leaflet-container .leaflet-control-attribution a {
    color: #f87171;
  }
  .hackathon-map-shell .leaflet-bar a {
    background: #fafafa;
    color: #404040;
    border-color: #e5e5e5;
  }
  .hackathon-map-shell .leaflet-bar a:hover {
    background: #f5f5f5;
    color: #ff0101;
  }
  .dark .hackathon-map-shell .leaflet-bar a {
    background: #404040;
    color: #e5e5e5;
    border-color: #525252;
  }
  .dark .hackathon-map-shell .leaflet-bar a:hover {
    background: #525252;
    color: #ff3838;
  }
</style>
