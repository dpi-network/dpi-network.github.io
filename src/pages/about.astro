---
import MainLayout from "@/layouts/MainLayout.astro";
import Team from "@components/Team.astro";
import { SITE } from "@data/constants";
import { people } from "@data/people";

const pageTitle: string = `About Us | ${SITE.title}`;
const metaDescription =
  "Meet the Data for Public Impact Network team: executive board, policy hackathon leads across cities, advisory board, and honorary members.";
const ogTitle = `About Us | ${SITE.title}`;

const title: string = "Our Team";
const subTitle: string =
  "Turning outreach and caffeine into events and organizations!";
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${SITE.url}about`,
    url: `${SITE.url}about`,
    name: pageTitle,
    description: metaDescription,
    isPartOf: {
      "@type": "WebSite",
      url: SITE.url,
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: "en-US",
  }}
>
  <div class="mx-auto mt-12 max-w-2xl px-4 lg:max-w-5xl lg:px-6">
    <div class="text-center">
      <h1
        class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>
    <Team members={people} />
  </div>
</MainLayout>
