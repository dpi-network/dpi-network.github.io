---
import MainLayout from "@/layouts/MainLayout.astro";
import { SITE } from "@data/constants";
import { getSortedVisibleBlogPosts } from "@data/blogPosts";
import { formatDate } from "@utils/utils";

const posts = getSortedVisibleBlogPosts();

const pageTitle: string = `Blog | ${SITE.title}`;
const metaDescription =
  "Updates, stories, and perspectives from the Data for Public Impact Network — policy hackathons, partnerships, and community.";
const ogTitle = `Blog | ${SITE.title}`;

const title = "Blog";
const subTitle =
  "News, reflections, and ideas from our network.";
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "Blog",
    "@id": `${SITE.url}blog`,
    url: `${SITE.url}blog`,
    name: pageTitle,
    description: metaDescription,
    isPartOf: {
      "@type": "WebSite",
      url: SITE.url,
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: "en-US",
  }}
>
  <div
    class="mx-auto mt-12 max-w-2xl px-4 pb-16 md:pb-20 lg:max-w-5xl lg:px-6 lg:pb-24"
  >
    <div class="text-center">
      <h1
        class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-4xl md:leading-tight"
      >
        {title}
      </h1>
      <p class="mx-auto mt-2 max-w-3xl text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <ul class="mt-12 grid gap-8 sm:grid-cols-2 lg:gap-10">
      {
        posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.slug}/`}
              class="group flex h-full flex-col overflow-hidden rounded-2xl border border-neutral-300 bg-white shadow-sm transition hover:border-red-200 hover:shadow-md dark:border-neutral-600 dark:bg-neutral-800/50 dark:hover:border-red-900/40"
              data-astro-prefetch
            >
              <div class="aspect-[1200/630] w-full overflow-hidden bg-neutral-100 dark:bg-neutral-900">
                <img
                  src={post.coverUrl}
                  alt=""
                  width={1200}
                  height={630}
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
                  loading="lazy"
                />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <p class="text-xs font-medium text-neutral-500 dark:text-neutral-400">
                  <span class="sr-only">Author: </span>
                  <span>By {post.author}</span>
                  <span class="mx-2 text-neutral-300 dark:text-neutral-600" aria-hidden="true"
                    >·</span
                  >
                  <time datetime={post.pubDate.toISOString()}>
                    {formatDate(post.pubDate)}
                  </time>
                </p>
                <h2 class="mt-2 text-xl font-semibold text-neutral-900 transition group-hover:text-[#ff0101] dark:text-neutral-100 dark:group-hover:text-[#ff3838]">
                  {post.title}
                </h2>
                <p class="mt-2 flex-1 text-pretty text-sm text-neutral-600 dark:text-neutral-400">
                  {post.description}
                </p>
                <span
                  class="mt-4 inline-flex text-sm font-medium text-[#ff0101] dark:text-[#ff3838]"
                >
                  Read more →
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</MainLayout>
