---
import MainLayout from "@/layouts/MainLayout.astro";
import { SITE } from "@data/constants";
import { isBlogPostHiddenFromPublic } from "@data/blogPosts";

interface Props {
  slug: string;
  pageTitle: string;
  customDescription: string;
  customOgTitle: string;
  structuredData: object;
}

const {
  slug,
  pageTitle,
  customDescription,
  customOgTitle,
  structuredData,
} = Astro.props;

const hidden = isBlogPostHiddenFromPublic(slug);
---

{
  hidden ? (
    <MainLayout
      title={`Post unavailable | ${SITE.title}`}
      customDescription="This article is not published."
      customOgTitle={`Post unavailable | ${SITE.title}`}
      structuredData={undefined}
      robotsNoIndex={true}
    >
      <div class="mx-auto mt-12 max-w-lg px-4 pb-16 text-center lg:px-6">
        <h1 class="text-balance text-2xl font-bold tracking-tight text-neutral-800 dark:text-neutral-200 md:text-3xl">
          This article isn’t available
        </h1>
        <p class="mt-3 text-pretty text-neutral-600 dark:text-neutral-400">
          It may have been unpublished or is not ready for the public blog yet.
        </p>
        <a
          href="/blog/"
          class="mt-8 inline-flex text-sm font-medium text-[#ff0101] underline-offset-2 hover:underline dark:text-[#ff3838]"
        >
          ← Back to blog
        </a>
      </div>
    </MainLayout>
  ) : (
    <MainLayout
      title={pageTitle}
      customDescription={customDescription}
      customOgTitle={customOgTitle}
      structuredData={structuredData}
    >
      <slot />
    </MainLayout>
  )
}
